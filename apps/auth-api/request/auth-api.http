@baseUrl = http://localhost:3000/auth-api

### Root endpoint
GET {{baseUrl}}/

### GET all users (gig)
GET {{baseUrl}}/gig/users

### GET user by id (gig)
GET {{baseUrl}}/gig/users/1

### CREATE user (gig)
POST {{baseUrl}}/gig/users
Content-Type: application/json

{
  "name": "Nuevo Usuario",
  "email": "nuevo@ejemplo.com"
}

### UPDATE user (gig)
PUT {{baseUrl}}/gig/users/1
Content-Type: application/json

{
  "name": "Usuario Actualizado",
  "email": "actualizado@ejemplo.com"
}

### DELETE user (gig)
DELETE {{baseUrl}}/gig/users/1

### GET all users (private-gig)
GET {{baseUrl}}/private-gig/users

### GET user by id (private-gig)
GET {{baseUrl}}/private-gig/users/1

### CREATE user (private-gig)
POST {{baseUrl}}/private-gig/users
Content-Type: application/json

{
  "name": "Privado Usuario",
  "email": "privado@ejemplo.com"
}

### UPDATE user (private-gig)
PUT {{baseUrl}}/private-gig/users/1
Content-Type: application/json

{
  "name": "Privado Actualizado",
  "email": "privado_actualizado@ejemplo.com"
}

### DELETE user (private-gig)
DELETE {{baseUrl}}/private-gig/users/1

