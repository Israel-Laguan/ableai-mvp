{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "outputDirectory": "public",

  "builds": [
    {
      "src": "dist/apps/ai-manager-api/main.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "./libs/product-domain/backend/src/shared/infrastructure/drizzle/migrations/**/*",
        "memory": 1024,
        "maxDuration": 30
      }
    }
  ],

  "routes": [
    {
      "src": "/api/ai-manager-api/v1/(.*)",
      "dest": "/dist/apps/ai-manager-api/main.js",
      "methods": ["POST", "GET", "PUT", "DELETE", "PATCH"]
    }
  ]
}