#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

is_tag_push=false
changelog_modified=false

# Read local and remote references from pre-push input
while read local_ref local_sha remote_ref remote_sha
do
  # Detect if it's a push to a tag (remote ref starts with refs/tags/)
  if echo "$remote_ref" | grep -q "^refs/tags/"; then
    echo "Push de tag detectado. Omite la verificación de changelog."
    is_tag_push=true
    exit 0
  fi

  # Verify changes in changelog (only for non-tag pushes)
  if git diff origin/main..HEAD --name-only | grep -q "apps/developer-portal/src/docs/product/changelog/index.md"; then
    changelog_modified=true
  else
    echo "Error: changelog no ha sido modificado en esta rama. Debes actualizarlo antes de hacer el push."
    exit 1
  fi
done

if [ "$changelog_modified" = true ] && [ "$is_tag_push" = false ]; then
  npx nx run-many --target=build --all --skip-nx-cache
fi
